# Copy this file to .env.local and fill in. Never commit real keys.
# Restart `npm run dev` after every edit.

# ── Anthropic ─────────────────────────────────────────────────────
# Without this, every agent returns offline stubs (still useful for demo).
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ORCHESTRATOR=claude-opus-4-7
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001

# ── Supabase (database + auth + realtime) ─────────────────────────
# Without these, the app uses data/store.json (single-tenant, no real login).
#
# Setup:
#  1. Create a project at supabase.com.
#  2. SQL editor → paste + run:
#         supabase/migrations/0001_initial.sql
#         supabase/migrations/0002_dietary_and_menu.sql
#  3. Project Settings → API → copy URL + anon key + service role key below.
#  4. Authentication → URL Configuration → Site URL = http://localhost:3000,
#     redirect URL = http://localhost:3000/auth/callback (and your prod URL).
#  5. (Optional) Authentication → Providers → enable Google, paste the same
#     OAuth client ID/secret you'd use for Gmail.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Same values as above but exposed to the browser bundle (Next.js requires
# the NEXT_PUBLIC_ prefix). Just duplicate the URL + anon key here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Google OAuth (Gmail integration) ──────────────────────────────
# Without these, /inbox runs against a 5-message simulated fixture.
#
# Setup:
#  1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client (Web).
#  2. Authorized redirect URIs:
#         http://localhost:3000/api/gmail/callback
#         <your-prod-origin>/api/gmail/callback
#  3. Enable Gmail API + People API in the project.
#  4. Add scopes: gmail.readonly, gmail.send, gmail.modify, userinfo.email
#  5. Paste the client ID + secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── OpenAI (image generation) ─────────────────────────────────────
# Without this, Designer / Couturier / Quartermaster / Stationer render
# color swatches + text only (no actual photos / proofs).
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
